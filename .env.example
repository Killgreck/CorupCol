# ── Flask ──────────────────────────────────────────────────────────────────
# Genera un valor seguro con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-un-valor-aleatorio-seguro

# Pon en 1 solo en desarrollo local, NUNCA en producción
FLASK_DEBUG=0

# ── Base de datos ──────────────────────────────────────────────────────────
# Por defecto usa SQLite local. En producción puedes usar PostgreSQL:
# DATABASE_URL=postgresql://usuario:password@localhost/corupcol
DATABASE_URL=sqlite:///users.db

# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=cambia-esta-password

# ── Datos ──────────────────────────────────────────────────────────────────
DATA_DIR=/home/apolo/A/CorupCol/normalized
